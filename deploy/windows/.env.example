# CodeTalks Windows Remote Tools — Environment
# Copy to .env and fill in actual values.

# LLM API Keys (required for deepwiki)
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Embedding — use Ollama on Mac host
DEEPWIKI_EMBEDDING_BASE_URL=http://MAC_IP:11434
DEEPWIKI_EMBEDDING_API_KEY=unused
DEEPWIKI_EMBEDDER_TYPE=ollama
OLLAMA_BASE_URL=http://MAC_IP:11434
OLLAMA_HOST=http://MAC_IP:11434

# Mac host IP (for CodeCompass → PostgreSQL and Ollama)
MAC_IP=192.168.50.199
