{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/next-with-port.mjs dev",
    "build": "next build",
    "start": "node scripts/next-with-port.mjs start",
    "lint": "eslint",
    "test:e2e": "npx playwright test e2e/smoke-health.spec.ts e2e/smoke-workspace.spec.ts",
    "test:e2e:source-preview": "npx playwright test e2e/source-preview-real.spec.ts",
    "test:e2e:spdk": "sh -c 'export CODETALK_FRONTEND_PORT=${CODETALK_FRONTEND_PORT:-3003}; export CODETALK_BACKEND_PORT=${CODETALK_BACKEND_PORT:-3004}; export CODETALK_REUSE_EXISTING_SERVER=0; export CODETALK_E2E_REQUIRE_SPDK=1; export CODETALK_E2E_AUDIT_MODE=${CODETALK_E2E_AUDIT_MODE:-1}; export CODETALK_E2E_REPO=${CODETALK_E2E_REPO:-/Volumes/Media/dpdk/spdk}; export NEXT_PUBLIC_API_URL=http://localhost:${CODETALK_BACKEND_PORT}; exec npx playwright test e2e/spdk-real-e2e.spec.ts --project=chromium \"$@\"' --",
    "test:e2e:spdk:strict": "CODETALK_E2E_AUDIT_MODE=0 npm run test:e2e:spdk --",
    "test:e2e:release": "npx playwright test --config=playwright.release.config.ts",
    "test:ui-contract": "npx playwright test e2e/workspace-report-title.spec.ts",
    "test:e2e:ui": "npx playwright test --ui"
  },
  "dependencies": {
    "@hpcc-js/wasm-graphviz": "^1.21.2",
    "framer-motion": "^12.38.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.14.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "unified": "^11.0.5"
  }
}
