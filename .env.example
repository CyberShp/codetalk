POSTGRES_USER=codetalks
POSTGRES_PASSWORD=changeme
POSTGRES_DB=codetalks
DATABASE_URL=postgresql+asyncpg://codetalks:changeme@postgres:5432/codetalks

# LLM API Keys (at least one required for deepwiki)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Ollama (optional, for local LLM)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Encryption key for storing API keys (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=

# Tool URLs (override for host-run backend)
# JOERN_BASE_URL=http://localhost:8080
# SEMGREP_BASE_URL=http://localhost:9090

# External Agent discovery (Claude Code / Claude Code Router / OpenCode)
#
# CodeTalk checks the configured command from the backend process environment.
# In intranet deployments, prefer Claude Code Router:
#   CLAUDE_CODE_COMMAND=ccr code -p --output-format json
#
# If backend is started as a Windows service, scheduled task, IDE task, or Docker
# container, make sure that same process can resolve `ccr`. If not, use the full
# path to the shim/executable, for example:
#   CLAUDE_CODE_COMMAND="C:\Users\<you>\AppData\Roaming\npm\ccr.cmd" code -p --output-format json
#
# Optional fallback commands are tried when the primary executable is missing.
# In .env, use an empty value in strict intranet environments where plain Claude
# is not usable. In PowerShell environment variables, use JSON [] because
# `$env:CLAUDE_CODE_FALLBACK_COMMANDS=''` removes the variable.
#   CLAUDE_CODE_FALLBACK_COMMANDS=
#   CLAUDE_CODE_FALLBACK_COMMANDS=[]
#   CLAUDE_CODE_FALLBACK_COMMANDS=claude -p --output-format json
#
# OPENCODE_COMMAND=opencode
# OPENCODE_FALLBACK_COMMANDS=

# Repository storage path — must match WHERE repos were cloned, not where they appear in-container.
#
# Linux host (Compose or host-run):
#   Leave unset (defaults to /data/repos in container, or <repo>/.repos for host-run).
#
# Windows host + Docker Compose:
#   Set to the full Windows path of the host-side .repos directory so that paths
#   stored in the DB (e.g. D:\coworkers\codetalk\.repos\<hash>) can be correctly
#   mapped to the container mount at /data/repos/<hash>.
#   Example:
#     REPOS_BASE_PATH=D:\coworkers\codetalk\.repos
#
# Host-run backend (any OS):
#   Set to a writable absolute path, e.g.:
#     REPOS_BASE_PATH=/absolute/path/to/codetalk/.repos
# REPOS_BASE_PATH=

# Tool container repos path — only needed in mixed mode (host backend + dockerized tools).
# When REPOS_BASE_PATH points to a host-side directory and the tool runs inside Docker,
# set this to the path where that directory is mounted inside the tool container.
# Example (Windows host, tool in Docker mounting .repos at /data/repos):
#   TOOL_REPOS_BASE_PATH=/data/repos
# Leave unset for native mode or full-Docker mode (no path translation needed).
# TOOL_REPOS_BASE_PATH=

# Local repos directory for Docker mode — enables analyzing user-specified local folders.
#
# When a user inputs a local path (e.g. D:\projects\myapp) instead of a git URL, CodeTalks
# must mount that directory into the deepwiki container so it can read the file tree.
#
# Set LOCAL_REPOS_HOST_PATH to the HOST directory that CONTAINS your local project(s).
# The entire parent directory is mounted read-only at /local_repos inside the containers.
# docker-compose.yml uses this automatically; no other changes are needed.
#
# Windows host + Docker Compose example (analyze repos under D:\projects):
#   LOCAL_REPOS_HOST_PATH=D:\projects
#   Then analyze: D:\projects\myapp  (or any subdirectory)
#
# Linux/macOS host example:
#   LOCAL_REPOS_HOST_PATH=/home/user/projects
#
# Without this set: deepwiki returns 404 and the backend shows a friendly config error.
# Leave unset to disable local folder analysis in Docker mode.
# LOCAL_REPOS_HOST_PATH=

# CORS allowed origins (comma-separated). Must be explicit (no wildcard) when cookies are in use.
# Default covers common local dev ports; set to your production domain(s) in prod.
# CORS_ORIGINS=http://localhost:3000,http://localhost:3003,http://localhost:3004,http://localhost:3005
